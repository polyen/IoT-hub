# ============================================================================
# Mosquitto bridge — edge → VPS (activated in T3.4)
# Uncomment include_dir in mosquitto.conf to activate.
#
# This bridge uses mTLS (T3.1) for VPS connection.
# Topics forwarded: T1/T2 only (no T0, no actuators).
# On VPS disconnect: messages queue locally (max 100K).
# ============================================================================
connection vps-bridge
address ${VPS_MQTT_HOST}:8883

# mTLS auth (cert CN = vps-bridge, matches ACL in T3.2)
cafile   /mosquitto/config/certs/ca.crt
certfile /mosquitto/config/certs/vps-bridge.crt
keyfile  /mosquitto/config/certs/vps-bridge.key
tls_version tlsv1.3

# T1/T2 forwarded topics (QoS 1 ensures at-least-once delivery)
topic home/+/alert out 1
topic home/+/sensors out 1
topic home/+/camera/event out 1
# NB: home/+/presence (routine motion/occupancy) is intentionally NOT bridged —
# the VPS Telegram bot notifies on every home/+/alert, and presence ("who is
# home", tier 2) stays on the LAN. Keep motion off `alert` and out of this list.

# Bridge health
cleansession false
keepalive_interval 60
restart_timeout 10

# Local persistence queue (max 100K messages, ~50MB with avg 500B payload)
# mosquitto.conf must have: persistence true, persistence_location /mosquitto/data/
