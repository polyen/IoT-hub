# Qwen 3.5 4B Instruct Q4_K_M (Unsloth GGUF Dynamic 2.0) — llama-cpp-python HTTP server.
# Multi-arch: linux/arm64 (RPi5 16 GB with NEON), linux/amd64 (dev/VPS).
#
# Promoted from bench candidate (Phase 0) to production primary 2026-05 after
# benchmark in materials/evaluation_results/qwen3.5 validated tok/s ≥ 2.5 and
# accuracy gain over Qwen 2.5 3B across all four BFCL-style categories. The
# previous Qwen 2.5 3B baseline can still be loaded via docker-compose.bench.yml
# (now inverted to override BACK to qwen2.5-3b for regression re-runs).
#
# Override MODEL_URL + MODEL_PATH + MODEL_SHA256 from compose to switch versions
# without rebuilding the image.
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake curl coreutils \
    && rm -rf /var/lib/apt/lists/*

# Install llama-cpp-python with server extras, NEON-optimized for ARM64
ARG CMAKE_ARGS="-DLLAMA_NATIVE=ON"
RUN pip install --no-cache-dir "llama-cpp-python[server]==0.2.90" \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu

ENV MODEL_URL="https://huggingface.co/unsloth/Qwen3.5-4B-GGUF/resolve/main/Qwen3.5-4B-Q4_K_M.gguf" \
    MODEL_PATH="/app/models/qwen3.5-4b-q4_k_m.gguf" \
    MODEL_SHA256="" \
    HOST="0.0.0.0" \
    PORT="8001" \
    N_CTX="8192" \
    N_THREADS="6"

# Model auto-download + checksum verification on first start
COPY hub/edge/agent/llm_entrypoint.sh /app/llm_entrypoint.sh
RUN chmod +x /app/llm_entrypoint.sh

RUN useradd --create-home --no-log-init -r llmuser && \
    mkdir -p /app/models && \
    chown llmuser:llmuser /app/models
USER llmuser

EXPOSE 8001

HEALTHCHECK --interval=30s --timeout=10s --retries=5 \
    CMD curl -sf http://localhost:8001/v1/models || exit 1

CMD ["/app/llm_entrypoint.sh"]
