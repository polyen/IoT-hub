# Qwen 2.5 3B Instruct Q4_K_M — runs llama-cpp-python HTTP server.
# Multi-arch: linux/arm64 (RPi5 with NEON), linux/amd64 (dev/VPS).
#
# Note (2026-05): Qwen 3.x 4B is the project's stated primary LLM (see
# materials/iot_hub_project_summary.md) but is not yet pinned here — bumping
# requires re-benchmarking on the RPi5. Override MODEL_URL + MODEL_PATH +
# MODEL_SHA256 from compose to switch versions without rebuilding the image.
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake curl coreutils \
    && rm -rf /var/lib/apt/lists/*

# Install llama-cpp-python with server extras, NEON-optimized for ARM64
ARG CMAKE_ARGS="-DLLAMA_NATIVE=ON"
RUN pip install --no-cache-dir "llama-cpp-python[server]==0.2.90" \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu

ENV MODEL_URL="https://huggingface.co/Qwen/Qwen2.5-3B-Instruct-GGUF/resolve/main/qwen2.5-3b-instruct-q4_k_m.gguf" \
    MODEL_PATH="/app/models/qwen2.5-3b-instruct-q4_k_m.gguf" \
    MODEL_SHA256="" \
    HOST="0.0.0.0" \
    PORT="8001" \
    N_CTX="4096" \
    N_THREADS="4"

# Model auto-download + checksum verification on first start
COPY hub/edge/agent/llm_entrypoint.sh /app/llm_entrypoint.sh
RUN chmod +x /app/llm_entrypoint.sh

RUN useradd --create-home --no-log-init -r llmuser && \
    mkdir -p /app/models && \
    chown llmuser:llmuser /app/models
USER llmuser

EXPOSE 8001

HEALTHCHECK --interval=30s --timeout=10s --retries=5 \
    CMD curl -sf http://localhost:8001/v1/models || exit 1

CMD ["/app/llm_entrypoint.sh"]
