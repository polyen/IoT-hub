# Qwen 2.5 1.5B Instruct Q4_K_M — llama-cpp-python HTTP server.
# Multi-arch: linux/arm64 (RPi5 16 GB with NEON), linux/amd64 (dev/VPS).
#
# Qwen2.5-1.5B-Instruct: ~1.0 GB, ~7-12 tok/s on RPi5 ARM Cortex-A76
# (~3× faster than the 3B variant).  ChatML format via --chat_format chatml.
#
# Migration history:
#   2026-05 (initial)  : Qwen 3.5 4B Q4_K_M (~1.5 tok/s, llama.cpp bug #20182)
#   2026-05 (reverted) : Qwen 2.5 3B  Q4_K_M (~2-5 tok/s)
#   2026-05 (downsize) : Qwen 2.5 1.5B Q4_K_M — research showed 95%+ commands
#     are already resolved by the edge TextResolver; LLM is a fallback for
#     ~5% of requests, so we favor latency over capacity.  See
#     materials/llm_optimization_research.md §3 (Variant B).
#
# Override MODEL_URL + MODEL_PATH + MODEL_SHA256 from compose to switch versions
# without rebuilding the image.
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake curl coreutils \
    && rm -rf /var/lib/apt/lists/*

# Install llama-cpp-python with server extras, NEON-optimized for ARM64
# >=0.3.0 required for qwen35 (hybrid SSM+Transformer) architecture support
ARG CMAKE_ARGS="-DLLAMA_NATIVE=ON"
RUN pip install --no-cache-dir "llama-cpp-python[server]>=0.3.0" \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu

ENV MODEL_URL="https://huggingface.co/Qwen/Qwen2.5-1.5B-Instruct-GGUF/resolve/main/qwen2.5-1.5b-instruct-q4_k_m.gguf" \
    MODEL_PATH="/app/models/qwen2.5-1.5b-instruct-q4_k_m.gguf" \
    MODEL_SHA256="" \
    HOST="0.0.0.0" \
    PORT="8001" \
    N_CTX="4096" \
    N_THREADS="4"

# Model auto-download + checksum verification on first start
COPY hub/edge/agent/llm_entrypoint.sh /app/llm_entrypoint.sh
RUN chmod +x /app/llm_entrypoint.sh

RUN useradd --create-home --no-log-init -u 1001 llmuser && \
    mkdir -p /app/models && \
    chown llmuser:llmuser /app/models
USER llmuser

EXPOSE 8001

HEALTHCHECK --interval=30s --timeout=10s --retries=5 \
    CMD curl -sf http://localhost:8001/v1/models || exit 1

CMD ["/app/llm_entrypoint.sh"]
