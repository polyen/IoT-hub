# Qwen 3.5 4B Q4_K_M — runs llama-cpp-python HTTP server
# Multi-arch: linux/arm64 (RPi5 with NEON), linux/amd64 (dev/VPS)
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake curl \
    && rm -rf /var/lib/apt/lists/*

# Install llama-cpp-python with server extras, NEON-optimized for ARM64
ARG CMAKE_ARGS="-DLLAMA_NATIVE=ON"
RUN pip install --no-cache-dir "llama-cpp-python[server]==0.2.90" \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu

ENV MODEL_PATH="/app/models/qwen3.5-4b-q4_k_m.gguf" \
    HOST="0.0.0.0" \
    PORT="8001" \
    N_CTX="4096" \
    N_THREADS="4"

# Model auto-download on first start via entrypoint
COPY hub/edge/agent/llm_entrypoint.sh /app/llm_entrypoint.sh
RUN chmod +x /app/llm_entrypoint.sh

RUN useradd --create-home --no-log-init -r llmuser && \
    mkdir -p /app/models && \
    chown llmuser:llmuser /app/models
USER llmuser

EXPOSE 8001

HEALTHCHECK --interval=30s --timeout=10s --retries=5 \
    CMD curl -sf http://localhost:8001/health || exit 1

CMD ["/app/llm_entrypoint.sh"]
