root   ::= "{" ws "\"tool\":" ws tool "," ws "\"payload\":" ws obj "}"
tool   ::= "\"summarize_period\""
         | "\"query_events_db\""
         | "\"get_home_state\""
         | "\"send_push\""
         | "\"ask_user\""
         | "\"set_timer\""
         | "\"mqtt_publish\""
obj    ::= "{" ws (pair (ws "," ws pair)*)? ws "}"
pair   ::= string ws ":" ws val
val    ::= string | number | "true" | "false" | "null"
number ::= "-"? [0-9]+ ("." [0-9]+)?
string ::= "\"" [^"\\\n]* "\""
ws     ::= [ \t\n]*
