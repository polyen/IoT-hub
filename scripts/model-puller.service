[Unit]
Description=IoT Hub model puller — pull new HEF artifacts from GHCR and promote
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=/mnt/ssd/iot-hub/repo/.env
Environment=MODELS_DIR=/mnt/ssd/iot-hub/models
Environment=BACKEND_URL=http://localhost:8000
ExecStart=/mnt/ssd/iot-hub/repo/scripts/model-puller.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=model-puller
