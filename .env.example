# =============================================================================
# IoT Hub — Environment variables template
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=iothub
POSTGRES_USER=iothub
POSTGRES_PASSWORD=change_me_strong_password

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# No auth by default for internal network; set requirepass in redis.conf for prod
# REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# ---------------------------------------------------------------------------
# ntfy
# ---------------------------------------------------------------------------
# Edge: local URL (no internet required)
NTFY_BASE_URL=http://localhost:8080
# Cloud: public URL e.g. https://ntfy.example.com
# NTFY_BASE_URL=https://ntfy.example.com

# ---------------------------------------------------------------------------
# Telegram bot (cloud only)
# ---------------------------------------------------------------------------
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ---------------------------------------------------------------------------
# MLflow (training machine only — не використовується на edge)
# ---------------------------------------------------------------------------
# Встановлюй локально перед запуском dvc repro або training scripts.
# MLFLOW_TRACKING_URI=http://localhost:5001

# ---------------------------------------------------------------------------
# GHCR model registry (edge RPi — потрібно для model-puller.timer)
# ---------------------------------------------------------------------------
# GitHub PAT з правом read:packages. Використовується scripts/model-puller.sh
# для перевірки нових HEF артефактів у GHCR кожні 5 хвилин.
GHCR_OWNER=your_github_username
GHCR_TOKEN=ghp_your_read_packages_pat_here

# ---------------------------------------------------------------------------
# Backend / Agent
# ---------------------------------------------------------------------------
LOG_LEVEL=info

# Local LLM (llama-cpp-python server, container "llm")
# Default: Qwen 2.5 1.5B-Instruct Q4_K_M (~1.0 GB, 7-12 tok/s on Pi5).
# Override BOTH URL and PATH together to switch models without rebuilding image.
# LLM_MODEL_URL=https://huggingface.co/Qwen/Qwen2.5-1.5B-Instruct-GGUF/resolve/main/qwen2.5-1.5b-instruct-q4_k_m.gguf
# LLM_MODEL_PATH=/app/models/qwen2.5-1.5b-instruct-q4_k_m.gguf
# LLM_MODEL_SHA256=  # set to enforce integrity check on download
# Pi5 has 4 Cortex-A76 cores; llama.cpp tolerates slight oversubscription on
# this SoC — 6 worker threads measured marginally faster than 4 in practice.
LLM_N_THREADS=6
# 4096 fits our trimmed prompts (max 15 devices + history) with ~50 MB KV cache.
LLM_N_CTX=4096

# Optional: cloud LLM (non-sensitive tasks only — T0/T1 data)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# MQTT
# ---------------------------------------------------------------------------
MQTT_HOST=mosquitto
MQTT_PORT=1883
# mTLS port (activated in T3.1)
# MQTT_TLS_PORT=8883

# ---------------------------------------------------------------------------
# PostgreSQL exporter (use same credentials)
# DATA_SOURCE_NAME is built from POSTGRES_* above

# ---------------------------------------------------------------------------
# TLS certificate for web UI (HTTPS / microphone access)
# Generate with: ./scripts/gen-web-cert.sh
# ---------------------------------------------------------------------------
HUB_DOMAIN=iot-hub.local
CERTS_HOST_DIR=/opt/iot-hub/certs

# ---------------------------------------------------------------------------
# CV Pipeline
# ---------------------------------------------------------------------------
RTSP_URL=rtsp://mediamtx:8554/camera

# Detection confidence floors. CONF_THRESHOLD is the global floor (fire/smoke);
# CONF_THRESHOLD_PERSON is a lower per-class floor for person (class 0). The
# quantised YOLO26n person score hovers at ~0.5 at surveillance distance, so a
# single 0.5 floor makes the bbox flicker → ByteTrack re-IDs the person → the
# camera/identity stream floods with duplicate "Vlad" events. The lower person
# floor keeps detection continuous; fire/smoke stay strict to avoid false alarms.
CONF_THRESHOLD=0.5
CONF_THRESHOLD_PERSON=0.35
# Frames a track survives without a matching detection before ByteTrack drops it
# (track_buffer). At 15 fps, 45 ≈ 3 s — bridges brief detection gaps so a person
# keeps the same track_id instead of being re-IDed.
TRACK_BUFFER=45

# T0 frame storage — JPEG кадри хибних тривог для донавчання (active learning).
# Вкажи шлях до SSD/NVMe директорії (має бути на окремому пристрої від кореневої ФС).
# Потрібно створити директорію один раз:
#   sudo mkdir -p /mnt/ssd/edge-data && sudo chown $USER /mnt/ssd/edge-data
# CV (сервіс) зчитує T0_MOUNT напряму з iot-hub-cv.service (не з цього файлу).
# Для Docker-режиму CV bind-mount буде з цього шляху, тому шляхи збігаються з хостом.
# Якщо не вказано — використовується named Docker volume (кадри недоступні з хосту для mining).
T0_HOST_DIR=/mnt/ssd/edge-data
# Шлях на хості для збереження вручну розмічених кадрів (інструмент "Розмітити" у веб-інтерфейсі).
# Якщо вказати шлях до основного датасету — кадри одразу потрапляють туди і не потребують синхронізації.
# Якщо не вказано — використовується named Docker volume annotation-dataset (не видно з хосту).
ANNOTATION_HOST_DIR=/mnt/ssd/datasets/fire_smoke_mixed
# Camera stream URLs are stored in the DB via the floor-plan editor (Camera → Edit).
# Sub-stream (CV + mic): rtsp://admin:pass@IP/h264Preview_01_sub
# Main-stream (frontend HLS): rtsp://admin:pass@IP/h264Preview_01_main
# The backend configures mediamtx on startup and on every floor-plan save — no env vars needed.

# ---------------------------------------------------------------------------
# VPS MQTT (for bridge — set to your VPS hostname)
# ---------------------------------------------------------------------------
VPS_MQTT_HOST=vps.example.com

# ---------------------------------------------------------------------------
# Voice / STT
# ---------------------------------------------------------------------------
# Engine selection: auto (CPU-first) | moonshine-uk | faster_whisper | hailo.
STT_BACKEND=auto
# Working Ukrainian engine — locally-exported Moonshine-base-uk ONNX (CPU, no
# torch). Export once: `python -m training.export_moonshine_onnx`. In-container
# path below; present → auto default, absent → falls back to faster-whisper.
MOONSHINE_ONNX_DIR=/app/models/moonshine-base-uk-onnx
# Fallback CPU Whisper size when the Moonshine ONNX dir is absent.
FASTER_WHISPER_MODEL=base
WHISPER_LANGUAGE=uk

# ---------------------------------------------------------------------------
# VPS / CD secrets (set in GitHub Actions, not here)
# VPS_HOST=
# VPS_USER=deploy
# VPS_SSH_KEY=   <- private key, GitHub Secret only
# GHCR_PAT=      <- GitHub PAT read:packages, GitHub Secret only
# GDRIVE_CREDENTIALS=  <- вміст ~/.config/dvc/tmp/gdrive-user-credentials.json, GitHub Secret only
# ---------------------------------------------------------------------------
