# =============================================================================
# IoT Hub — Environment variables template
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=iothub
POSTGRES_USER=iothub
POSTGRES_PASSWORD=change_me_strong_password

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# No auth by default for internal network; set requirepass in redis.conf for prod
# REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# ---------------------------------------------------------------------------
# ntfy
# ---------------------------------------------------------------------------
# Edge: local URL (no internet required)
NTFY_BASE_URL=http://localhost:8080
# Cloud: public URL e.g. https://ntfy.example.com
# NTFY_BASE_URL=https://ntfy.example.com

# ---------------------------------------------------------------------------
# Telegram bot (cloud only)
# ---------------------------------------------------------------------------
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ---------------------------------------------------------------------------
# MLflow (training machine only — не використовується на edge)
# ---------------------------------------------------------------------------
# Встановлюй локально перед запуском dvc repro або training scripts.
# MLFLOW_TRACKING_URI=http://localhost:5001

# ---------------------------------------------------------------------------
# GHCR model registry (edge RPi — потрібно для model-puller.timer)
# ---------------------------------------------------------------------------
# GitHub PAT з правом read:packages. Використовується scripts/model-puller.sh
# для перевірки нових HEF артефактів у GHCR кожні 5 хвилин.
GHCR_OWNER=your_github_username
GHCR_TOKEN=ghp_your_read_packages_pat_here

# ---------------------------------------------------------------------------
# Backend / Agent
# ---------------------------------------------------------------------------
LOG_LEVEL=info

# Ollama endpoint for local LLM (edge)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Optional: cloud LLM (non-sensitive tasks only — T0/T1 data)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# MQTT
# ---------------------------------------------------------------------------
MQTT_HOST=mosquitto
MQTT_PORT=1883
# mTLS port (activated in T3.1)
# MQTT_TLS_PORT=8883

# ---------------------------------------------------------------------------
# PostgreSQL exporter (use same credentials)
# DATA_SOURCE_NAME is built from POSTGRES_* above

# ---------------------------------------------------------------------------
# CV Pipeline
# ---------------------------------------------------------------------------
RTSP_URL=rtsp://camera.local:554/stream

# ---------------------------------------------------------------------------
# VPS MQTT (for bridge — set to your VPS hostname)
# ---------------------------------------------------------------------------
VPS_MQTT_HOST=vps.example.com

# ---------------------------------------------------------------------------
# VPS / CD secrets (set in GitHub Actions, not here)
# VPS_HOST=
# VPS_USER=deploy
# VPS_SSH_KEY=   <- private key, GitHub Secret only
# GHCR_PAT=      <- GitHub PAT read:packages, GitHub Secret only
# ---------------------------------------------------------------------------
